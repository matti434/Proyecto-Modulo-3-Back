# Servidor
PORT=5000
NODE_ENV=development

# Base de datos
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/rolling-motors

# JWT
JWT_SECRET=tu-secret-super-seguro
JWT_EXPIRES_IN=7d

# Frontend (CORS y redirección MercadoPago después del pago)
# Desarrollo: http://localhost:5173  |  Producción: https://tu-app.netlify.app
FRONTEND_URL=http://localhost:5173

# Resend (emails - contacto, recuperación de contraseña)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=onboarding@resend.dev
CONTACTO_EMAIL=destino@empresa.com

# Cloudinary (opcional - imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MercadoPago (pasarela de pagos)
MERCADOPAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADOPAGO_CURRENCY=ARS
# MP_USAR_SANDBOX=true para forzar sandbox (por defecto usa init_point para evitar errores de cookies)

# URL del backend (para webhook de MercadoPago - debe ser accesible desde internet en producción)
BACKEND_URL=http://localhost:5000
